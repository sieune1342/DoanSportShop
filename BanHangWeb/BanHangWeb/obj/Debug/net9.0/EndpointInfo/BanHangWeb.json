          "orderDate": {
            "type": "string",
            "format": "date-time"
          },
          "totalPrice": {
            "type": "number",
            "format": "double"
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "shippingFee": {
            "type": "number",
            "format": "double"
          },
          "totalPayment": {
            "type": "number",
            "format": "double"
          },
          "status": {
            "type": "string",
            "nullable": true
          },
          "orderDetails": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderDetail"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
