@model BanHangWeb.Models.Product

@using System.Text.Json
@using System.Collections.Generic

@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm";

    var sizesList = string.IsNullOrEmpty(Model.Sizes)
        ? new List<string>()
        : JsonSerializer.Deserialize<List<string>>(Model.Sizes);
    var colorsList = string.IsNullOrEmpty(Model.Colors)
   ? new List<string>()
   : JsonSerializer.Deserialize<List<string>>(Model.Colors);
}

<div class="container mt-4">
    <div class="card shadow-sm p-4 rounded-4 bg-light">
        <h2 class="mb-4 text-primary">
            <i class="bi bi-pencil-square"></i> Cập nhật sản phẩm
        </h2>

        <form asp-action="Edit" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Tên sản phẩm</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Price" class="form-label">Giá</label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label">Danh mục</label>
                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId">
                    <option value="">-- Chọn danh mục --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Quantity" class="form-label">Số lượng</label>
                <input asp-for="Quantity" class="form-control" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>

            <!-- Size -->
            <div class="mb-3">
                <label class="form-label">📏 Size</label>
                <input type="text" id="sizeInput" class="form-control" placeholder="Nhập size, nhấn Enter để thêm" />
                <div id="sizeList" class="mt-2"></div>
                <input type="hidden" asp-for="Sizes" id="SizesHidden" />
            </div>

            <!-- Color -->
            <div class="mb-3">
                <label class="form-label">🎨 Màu</label>
                <input type="text" id="colorInput" class="form-control" placeholder="Nhập màu, nhấn Enter để thêm" />
                <div id="colorList" class="mt-2"></div>
                <input type="hidden" asp-for="Colors" id="ColorsHidden" />
            </div>


            <!-- Ảnh sản phẩm -->
            <div class="mb-3">
                <label class="form-label">Ảnh sản phẩm hiện tại:</label><br />
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" width="120" class="rounded-3 shadow-sm border border-secondary-subtle mb-2" />
                }
            </div>

            <div class="mb-3">
                <label asp-for="ImageFile" class="form-label">Chọn ảnh mới (nếu có)</label>
                <input type="file" asp-for="ImageFile" class="form-control" />
            </div>

            <!-- Nút -->
            <div class="mt-4">
                <button type="submit" class="btn btn-success me-2">
                    <i class="bi bi-save"></i> Lưu thay đổi
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Script xử lý size -->
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            let sizes = @Html.Raw(JsonSerializer.Serialize(sizesList));

            function updateHiddenFields() {
                document.getElementById("SizesHidden").value = JSON.stringify(sizes);
            }

            function renderBadges(listId, dataArray, removeClass) {
                const list = document.getElementById(listId);
                list.innerHTML = '';
                dataArray.forEach(item => {
                    const span = document.createElement("span");
                    span.classList.add("badge", "bg-secondary", "me-2", "mb-1");
                    span.innerHTML = `${item} <span class="${removeClass}" style="cursor:pointer;">❌</span>`;
                    list.appendChild(span);
                });
            }

            function addBadge(listId, inputId, dataArray, removeClass) {
                const input = document.getElementById(inputId);
                const list = document.getElementById(listId);

                input.addEventListener("keypress", function (event) {
                    if (event.key === "Enter" && input.value.trim() !== "") {
                        event.preventDefault();
                        const newItem = input.value.trim();
                        if (!dataArray.includes(newItem)) {
                            dataArray.push(newItem);
                            renderBadges(listId, dataArray, removeClass);
                            updateHiddenFields();
                        }
                        input.value = "";
                    }
                });

                list.addEventListener("click", function (event) {
                    if (event.target.classList.contains(removeClass)) {
                        const item = event.target.parentNode.textContent.trim().replace(" ❌", "");
                        const index = dataArray.indexOf(item);
                        if (index !== -1) {
                            dataArray.splice(index, 1);
                            renderBadges(listId, dataArray, removeClass);
                            updateHiddenFields();
                        }
                    }
                });

                renderBadges(listId, dataArray, removeClass);
            }

            addBadge("sizeList", "sizeInput", sizes, "remove-size");
            updateHiddenFields();
        });
    </script>
    <!-- Script xử lý màu -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            let colors = @Html.Raw(JsonSerializer.Serialize(colorsList));

            function updateHiddenFieldsColor() {
                document.getElementById("ColorsHidden").value = JSON.stringify(colors);
            }

            function renderBadgesColor(listId, dataArray, removeClass) {
                const list = document.getElementById(listId);
                list.innerHTML = '';
                dataArray.forEach(item => {
                    const span = document.createElement("span");
                    span.classList.add("badge", "bg-secondary", "me-2", "mb-1");
                    span.innerHTML = `${item} <span class="${removeClass}" style="cursor:pointer;">❌</span>`;
                    list.appendChild(span);
                });
            }

            function addBadgeColor(listId, inputId, dataArray, removeClass) {
                const input = document.getElementById(inputId);
                const list = document.getElementById(listId);

                input.addEventListener("keypress", function (event) {
                    if (event.key === "Enter" && input.value.trim() !== "") {
                        event.preventDefault();
                        const newItem = input.value.trim();
                        if (!dataArray.includes(newItem)) {
                            dataArray.push(newItem);
                            renderBadgesColor(listId, dataArray, removeClass);
                            updateHiddenFieldsColor();
                        }
                        input.value = "";
                    }
                });

                list.addEventListener("click", function (event) {
                    if (event.target.classList.contains(removeClass)) {
                        const item = event.target.parentNode.textContent.trim().replace(" ❌", "");
                        const index = dataArray.indexOf(item);
                        if (index !== -1) {
                            dataArray.splice(index, 1);
                            renderBadgesColor(listId, dataArray, removeClass);
                            updateHiddenFieldsColor();
                        }
                    }
                });

                renderBadgesColor(listId, dataArray, removeClass);
            }

            addBadgeColor("colorList", "colorInput", colors, "remove-color");
            updateHiddenFieldsColor();
        });
    </script>

}
