@model IEnumerable<BanHangWeb.Models.Product>

@{
    ViewData["Title"] = "Danh sách sản phẩm";
    var selectedCategoryId = ViewBag.SelectedCategoryId?.ToString();
    var categories = ViewBag.Categories as SelectList;
}

<div class="container py-4">
    <h2 class="mb-4 text-primary fw-bold">👟 Danh sách sản phẩm</h2>

    <!-- 🔍 Bộ lọc -->
    <form method="get" asp-action="Index" class="row g-3 align-items-end mb-4">
        <div class="col-md-5">
            <label class="form-label">🔍 Tìm kiếm theo tên</label>
            <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control" placeholder="Nhập tên sản phẩm..." />
        </div>
        <div class="col-md-4">
            <label class="form-label">👕 Danh mục</label>
            <select name="categoryId" class="form-select">
                <option value="">-- Tất cả danh mục --</option>
                @if (categories != null)
                {
                    @foreach (var category in categories)
                    {
                        <option value="@category.Value" selected="@(selectedCategoryId == category.Value ? "selected" : null)">
                            @category.Text
                        </option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-outline-primary w-100">🔍 Lọc sản phẩm</button>
        </div>
    </form>

    <!-- 👤 Chức năng dành cho Admin -->
    @if (User.IsInRole("Admin"))
    {
        <div class="mb-3 text-end">
            <a asp-action="Create" class="btn btn-success">➕ Thêm món mới</a>
        </div>
    }

    <!-- 📋 Danh sách sản phẩm -->
    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var item in Model)
        {
            var sizes = new List<string>();

            try
            {
                if (!string.IsNullOrEmpty(item.Sizes))
                {
                    sizes = System.Text.Json.JsonSerializer.Deserialize<List<string>>(item.Sizes) ?? new List<string>();
                }
            }
            catch
            {
                // Có thể log lỗi nếu cần
            }

            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <img src="@item.ImageUrl" class="card-img-top rounded-2" style="height: 220px; object-fit: cover;" alt="@item.Name" />
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-dark fw-semibold">@item.Name</h5>
                        <p class="text-muted small">@item.Category?.Name</p>
                        <p class="text-danger fw-bold">@item.Price.ToString("#,##0") VNĐ</p>

                        <div class="mt-auto">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm w-100 mb-2">🔍 Xem chi tiết</a>

                            @if (User.IsInRole("Admin"))
                            {
                                <div class="d-flex gap-2 mb-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm w-50">✏️ Sửa</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm w-50">🗑 Xóa</a>
                                </div>
                            }

                            @if (User.Identity.IsAuthenticated)
                            {
                                <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-grid gap-2">
                                    <input type="hidden" name="productId" value="@item.Id" />

                                    <!-- Size -->
                                    @if (sizes.Any())
                                    {
                                        <select name="selectedSize" class="form-select form-select-sm" required
                                                oninvalid="this.setCustomValidity('Vui lòng chọn kích cỡ')"
                                                oninput="this.setCustomValidity('')">
                                            <option value="">-- Size --</option>
                                            @foreach (var size in sizes)
                                            {
                                                <option value="@size">@size</option>
                                            }
                                        </select>
                                    }
                                    else
                                    {
                                        <select class="form-select form-select-sm" disabled>
                                            <option>Không có size</option>
                                        </select>
                                    }

                                    <button type="submit" class="btn btn-success btn-sm mt-2">🛒 Thêm vào giỏ</button>
                                </form>
                            }
                            else
                            {
                                <a asp-area="Identity" asp-page="/Account/Login"
                                   asp-route-returnUrl="@Url.Action("Index", "Products")"
                                   class="btn btn-secondary btn-sm w-100">
                                    🔒 Đăng nhập để mua
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
