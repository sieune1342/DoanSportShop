@model BanHangWeb.Models.Order

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<h2>@ViewData["Title"]</h2>

<h3>🧾 Thông tin khách hàng: @Model.CustomerName</h3>
<p><strong>📍 Địa chỉ:</strong> @Model.Address</p>
<p><strong>📧 Email:</strong> @Model.Email</p>
<p><strong>📞 Số điện thoại:</strong> @Model.Phone</p>
<p><strong>📝 Ghi chú:</strong> @Model.Note</p>

<p><strong>🗓️ Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
<p><strong>💵 Tổng tiền:</strong> @Model.TotalPrice.ToString("N0") ₫</p>

<h4>📦 Danh sách sản phẩm trong đơn hàng</h4>

@if (Model.OrderDetails != null && Model.OrderDetails.Any())
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Tên sản phẩm</th>
                <th>Số lượng</th>
                <th>Giá</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.OrderDetails)
            {
                <tr>
                    <td>@item.Product?.Name</td>
                    <td>@item.Quantity</td>
                    <td>@item.Product?.Price.ToString("N0") ₫</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>Không có sản phẩm trong đơn hàng.</p>
}

<h4>🚚 Trạng thái đơn hàng: <strong>@Model.Status</strong></h4>

<!-- Nút Quay lại -->
<a href="@Url.Action("MyOrders", "Orders")" class="btn btn-secondary mt-3">⬅️ Quay lại</a>
