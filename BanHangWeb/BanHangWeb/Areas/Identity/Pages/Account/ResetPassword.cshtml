@page
@model BanHangWeb.Areas.Identity.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

@section Styles {
    <style>
        .auth-page {
            min-height: 100vh;
            padding: 40px 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: radial-gradient(circle at top left, #243b6b 0, #021024 40%, #000814 100%);
        }

        .auth-card {
            max-width: 420px;
            width: 100%;
            border-radius: 24px;
            background: #201a2f;
            box-shadow: 0 40px 80px rgba(0, 0, 0, 0.7);
            padding: 40px 32px;
            color: #f5f3ff;
        }

        .auth-title {
            font-weight: 700;
            margin-bottom: 8px;
        }

        .auth-subtitle {
            margin-bottom: 24px;
            color: #a29cc5;
        }

        .auth-card .form-control {
            border-radius: 12px;
            border: 1px solid #433b60;
            background: #2b233f;
            color: #f5f3ff;
            padding: 12px 14px;
        }

            .auth-card .form-control::placeholder {
                color: #7e759f;
            }

            .auth-card .form-control:focus {
                border-color: #a855ff;
                box-shadow: 0 0 0 1px rgba(168, 85, 255, 0.6);
            }

        .auth-card button[type="submit"] {
            border-radius: 14px;
            background: linear-gradient(90deg, #a855ff, #6366f1);
            border: none;
            padding: 12px 16px;
            font-weight: 600;
        }

            .auth-card button[type="submit"]:hover {
                filter: brightness(1.05);
            }

        .auth-card .text-danger {
            font-size: 0.85rem;
        }

        @@media (max-width: 576px) {
            .auth-card {
                padding: 32px 20px;
                border-radius: 18px;
            }
        }
    </style>
}

<div class="auth-page">
    <div class="auth-card">
        <h2 class="auth-title">Đặt lại mật khẩu</h2>
        <p class="auth-subtitle">Nhập email và mật khẩu mới của bạn.</p>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input asp-for="Input.Code" type="hidden" />

            <div class="mb-3">
                <input asp-for="Input.Email"
                       class="form-control"
                       placeholder="Email" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <input asp-for="Input.Password"
                       class="form-control"
                       placeholder="Mật khẩu mới" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <input asp-for="Input.ConfirmPassword"
                       class="form-control"
                       placeholder="Xác nhận mật khẩu" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">
                Reset mật khẩu
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
