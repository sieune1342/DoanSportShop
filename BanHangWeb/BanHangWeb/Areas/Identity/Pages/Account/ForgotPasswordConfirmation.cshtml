@page
@model BanHangWeb.Areas.Identity.Pages.Account.ForgotPasswordConfirmationModel
@{
    ViewData["Title"] = "Forgot password confirmation";
}

@section Styles {
    <style>
        .auth-page {
            min-height: 100vh;
            padding: 40px 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: radial-gradient(circle at top left, #243b6b 0, #021024 40%, #000814 100%);
        }

        .auth-card {
            max-width: 520px;
            width: 100%;
            border-radius: 24px;
            background: #201a2f;
            box-shadow: 0 40px 80px rgba(0, 0, 0, 0.7);
            padding: 40px 32px;
            color: #f5f3ff;
            text-align: center;
        }

            .auth-card h2 {
                font-weight: 700;
                margin-bottom: 12px;
            }

            .auth-card p {
                margin-bottom: 0;
                color: #c4b5fd;
            }

        .auth-actions {
            margin-top: 28px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        @@media (min-width: 576px) {
            .auth-actions {
                flex-direction: row;
            }
        }
    </style>
}

<div class="auth-page">
    <div class="auth-card">
        <h2>Kiểm tra email của bạn</h2>
        <p>Chúng tôi đã gửi một liên kết đặt lại mật khẩu tới email của bạn.</p>
        <p class="mt-2">Nếu không thấy email, hãy kiểm tra hộp thư rác (Spam) hoặc thử lại.</p>

        @if (TempData["ResendOk"] is bool ok && ok)
        {
            <p class="mt-3 text-success small">
                Đã gửi lại liên kết đặt lại mật khẩu. Vui lòng kiểm tra email của bạn.
            </p>
        }

        <div class="auth-actions">
            <!-- Quay về trang nhập email -->
            <a asp-page="./ForgotPassword"
               class="btn btn-outline-light w-100">
                ← Quay lại nhập email
            </a>

            <!-- Gửi lại liên kết -->
            <form method="post" asp-page-handler="Resend" class="w-100">
                <input type="hidden" asp-for="Email" />
                <button type="submit" class="btn btn-primary w-100">
                    Gửi lại liên kết
                </button>
            </form>
        </div>
    </div>
</div>
